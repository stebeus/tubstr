{
	"$schema": "https://biomejs.dev/schemas/2.5.5/schema.json",
	"extends": ["@stebeus/biome-config"],
	"linter": {
		"domains": {
			"solid": "all"
		},
		"rules": {
			"nursery": {
				"useBaseline": "on"
			},
			"style": {
				"noHexColors": "on"
			}
		}
	},
	"css": {
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"html": {
		"formatter": {
			"enabled": true
		}
	},
	"assist": {
		"actions": {
			"source": {
				"noDuplicateClasses": "on",
				"useSortedProperties": "on"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/*.{jsx,tsx}"],
			"linter": {
				"rules": {
					"style": {
						"useNamingConvention": {
							"level": "on",
							"options": {
								"conventions": [
									{
										"formats": ["camelCase", "PascalCase"],
										"selector": {
											"kind": "objectLiteralProperty"
										}
									}
								]
							}
						}
					}
				}
			}
		},
		{
			"includes": ["**/*.svg"],
			"linter": {
				"rules": {
					"a11y": {
						"noSvgWithoutTitle": "off"
					}
				}
			}
		}
	]
}
